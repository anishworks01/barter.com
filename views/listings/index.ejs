<style>
#filters{
    display: flex;
    flex-wrap: wrap;
}
.filter{
  text-align: center;
  margin-right: 2rem;
  margin-top: 2rem;
  opacity: 0.7;
}
.filter:hover{
  opacity: 1;
  cursor: pointer;
}
.filter p {
  font-size: 0.8 rem;
}
</style>




